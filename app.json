{
  "expo": {
    "name": "Credit Disk",
    "slug": "credit-card-payoff-planner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#004aad"
    },
    "ios": {
      "bundleIdentifier": "com.sawantaryan.creditcardpayoffplanner",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sawantaryan.creditcardpayoffplanner",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-logo.png",
        "backgroundColor": "#FFFAEF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/app-logo.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "b6349e28-b317-4ca9-aa58-9258077a81ec"
      }
    },
    "owner": "sawantaryan"
  }
}
